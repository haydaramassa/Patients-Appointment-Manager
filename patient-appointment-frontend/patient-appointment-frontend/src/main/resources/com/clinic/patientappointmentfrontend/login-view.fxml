<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinic.patientappointmentfrontend.LoginController"
            styleClass="main-root">

    <center>
        <HBox alignment="CENTER" spacing="40.0">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <VBox spacing="12.0" maxWidth="320">
                <Label text="Patient Appointment Manager" styleClass="brand-title"/>

                <Label text="Smart and simple clinic management for appointments, patients, and staff."
                       wrapText="true"
                       styleClass="brand-subtitle"/>
            </VBox>

            <Region prefWidth="30"/>

            <VBox alignment="CENTER_LEFT"
                  spacing="14.0"
                  maxWidth="360"
                  prefWidth="360"
                  styleClass="login-card">

                <Label text="Login" styleClass="login-title"/>

                <Label text="Please enter your account details"
                       styleClass="login-subtitle"/>

                <TextField fx:id="emailField"
                           promptText="Email"
                           prefWidth="300"
                           styleClass="input-field"/>

                <PasswordField fx:id="passwordField"
                               promptText="Password"
                               prefWidth="300"
                               styleClass="input-field"/>

                <Button text="Login"
                        onAction="#onLoginClick"
                        styleClass="login-button"/>

                <Label fx:id="statusLabel"
                       text="Ready"
                       styleClass="status-label"/>
            </VBox>
        </HBox>
    </center>

</BorderPane>