<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinic.patientappointmentfrontend.LoginController"
            styleClass="main-root">

    <center>
        <StackPane>
            <Pane fx:id="animationPane"
                  mouseTransparent="true"
                  pickOnBounds="false"
                  styleClass="medical-animation-pane"/>

            <HBox alignment="CENTER" spacing="40.0">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <VBox spacing="12.0" maxWidth="360" prefWidth="360">
                    <Label text="Patient Appointment Manager"
                           wrapText="true"
                           styleClass="brand-title"/>

                    <Label text="Smart and simple clinic management for appointments, patients, and staff."
                           wrapText="true"
                           styleClass="brand-subtitle"/>
                </VBox>

                <Region prefWidth="30"/>

                <VBox alignment="CENTER_LEFT"
                      spacing="14.0"
                      maxWidth="420"
                      prefWidth="420"
                      styleClass="login-card">

                    <!-- LOGIN BOX -->
                    <VBox fx:id="loginBox" spacing="14.0">

                        <Label text="Login" styleClass="login-title"/>

                        <Label text="Please enter your account details"
                               styleClass="login-subtitle"/>

                        <TextField fx:id="emailField"
                                   promptText="Email"
                                   maxWidth="320"
                                   prefWidth="320"
                                   styleClass="input-field"/>

                        <PasswordField fx:id="passwordField"
                                       promptText="Password"
                                       maxWidth="320"
                                       prefWidth="320"
                                       styleClass="input-field"/>

                        <Button text="Login"
                                maxWidth="320"
                                prefWidth="320"
                                onAction="#onLoginClick"
                                styleClass="login-button"/>

                        <HBox alignment="CENTER" spacing="4" maxWidth="320" prefWidth="320">
                            <Label text="You don't have an account? click"
                                   styleClass="small-text"/>
                            <Hyperlink text="here"
                                       onAction="#showRegisterForm"
                                       styleClass="link-text"/>
                        </HBox>

                        <Label fx:id="statusLabel"
                               text="Ready"
                               maxWidth="320"
                               prefWidth="320"
                               wrapText="true"
                               styleClass="status-label"/>
                    </VBox>

                    <!-- REGISTER BOX -->
                    <VBox fx:id="registerBox"
                          spacing="12.0"
                          visible="false"
                          managed="false">

                        <Label text="Create Account" styleClass="login-title"/>

                        <Label text="Register a new clinic user account"
                               styleClass="login-subtitle"/>

                        <TextField fx:id="registerFullNameField"
                                   promptText="Full name"
                                   maxWidth="320"
                                   prefWidth="320"
                                   styleClass="input-field"/>

                        <TextField fx:id="registerEmailField"
                                   promptText="Email"
                                   maxWidth="320"
                                   prefWidth="320"
                                   styleClass="input-field"/>

                        <PasswordField fx:id="registerPasswordField"
                                       promptText="Password"
                                       maxWidth="320"
                                       prefWidth="320"
                                       styleClass="input-field"/>

                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Confirm password"
                                       maxWidth="320"
                                       prefWidth="320"
                                       styleClass="input-field"/>

                        <ProgressBar fx:id="passwordStrengthBar"
                                     progress="0"
                                     maxWidth="320"
                                     prefWidth="320"
                                     styleClass="password-strength-bar"/>

                        <Label fx:id="passwordStrengthLabel"
                               text="Password strength"
                               styleClass="password-hint"/>

                        <Label text="New accounts are created as SECRETARY accounts."
                               maxWidth="320"
                               prefWidth="320"
                               wrapText="true"
                               styleClass="role-info-label"/>

                        <Button text="Register"
                                maxWidth="320"
                                prefWidth="320"
                                onAction="#onRegisterClick"
                                styleClass="login-button"/>

                        <HBox alignment="CENTER" spacing="4" maxWidth="320" prefWidth="320">
                            <Label text="Already have an account?"
                                   styleClass="small-text"/>
                            <Hyperlink text="Back to login"
                                       onAction="#showLoginForm"
                                       styleClass="link-text"/>
                        </HBox>

                        <Label fx:id="registerStatusLabel"
                               text="Ready"
                               maxWidth="320"
                               prefWidth="320"
                               wrapText="true"
                               styleClass="status-label"/>
                    </VBox>

                </VBox>
            </HBox>
        </StackPane>
    </center>

</BorderPane>