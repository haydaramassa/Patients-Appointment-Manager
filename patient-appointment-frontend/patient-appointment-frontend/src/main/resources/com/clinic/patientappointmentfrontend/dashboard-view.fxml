<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinic.patientappointmentfrontend.DashboardController"
            styleClass="dashboard-root">

    <left>
        <VBox prefWidth="240" spacing="18" styleClass="sidebar">
            <padding>
                <Insets top="25" right="20" bottom="25" left="20"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Circle radius="18" styleClass="clinic-logo-circle"/>
                <VBox spacing="2">
                    <Label fx:id="clinicNameSidebarLabel"
                           text="Clinic"
                           wrapText="true"
                           styleClass="sidebar-title"/>

                    <Label text="Management System"
                           styleClass="sidebar-subtitle"/>
                </VBox>
            </HBox>

            <Button text="Dashboard"
                    styleClass="sidebar-button"/>

            <Button text="Patients"
                    onAction="#onPatientsClick"
                    styleClass="sidebar-button"/>

            <Button text="Appointments"
                    onAction="#onAppointmentsClick"
                    styleClass="sidebar-button"/>

            <Button text="Users"
                    fx:id="usersButton"
                    onAction="#onUsersClick"
                    styleClass="sidebar-button"/>

            <Button text="Clinic Info"
                    onAction="#onClinicInfoClick"
                    styleClass="sidebar-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout"
                    onAction="#onLogoutClick"
                    styleClass="sidebar-logout-button"/>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="top-bar">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <VBox spacing="4">
                <Label fx:id="dashboardTitleLabel"
                       text="Dashboard"
                       styleClass="top-title"/>

                <Label fx:id="roleLabel"
                       text="Role"
                       styleClass="top-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="welcomeLabel"
                   text="Welcome"
                   styleClass="welcome-label"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="24" styleClass="dashboard-content">
            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>

            <VBox spacing="6">
                <Label fx:id="clinicNameMainLabel"
                       text="Clinic Name"
                       styleClass="dashboard-title"/>

                <Label fx:id="clinicSubtitleLabel"
                       text="Clinic Management System"
                       styleClass="dashboard-subtitle"/>
            </VBox>

            <GridPane hgap="18" vgap="18">
                <VBox GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="stat-card">
                    <Label text="Total Patients" styleClass="stat-title"/>
                    <Label fx:id="totalPatientsLabel" text="0" styleClass="stat-value"/>
                </VBox>

                <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="stat-card">
                    <Label text="Total Appointments" styleClass="stat-title"/>
                    <Label fx:id="totalAppointmentsLabel" text="0" styleClass="stat-value"/>
                </VBox>

                <VBox GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="stat-card">
                    <Label text="Today Appointments" styleClass="stat-title"/>
                    <Label fx:id="todayAppointmentsLabel" text="0" styleClass="stat-value"/>
                </VBox>

                <VBox GridPane.rowIndex="0" GridPane.columnIndex="3" styleClass="stat-card">
                    <Label text="Total Users" styleClass="stat-title"/>
                    <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value"/>
                </VBox>
            </GridPane>

            <HBox spacing="18">
                <VBox spacing="10" styleClass="content-card" prefWidth="520">
                    <Label text="Quick Summary" styleClass="section-title"/>

                    <Label text="Manage patients, appointments, users, and daily clinic activity from one organized dashboard."
                           wrapText="true"
                           styleClass="card-text"/>
                </VBox>

                <VBox spacing="10" styleClass="content-card" prefWidth="420">
                    <Label text="Clinic Information" styleClass="section-title"/>

                    <Label fx:id="clinicPhoneLabel"
                           text="Phone"
                           wrapText="true"
                           styleClass="card-text"/>

                    <Label fx:id="clinicAddressLabel"
                           text="Address"
                           wrapText="true"
                           styleClass="card-text"/>

                    <Label fx:id="clinicHoursLabel"
                           text="Working hours"
                           wrapText="true"
                           styleClass="card-text"/>
                </VBox>
            </HBox>
        </VBox>
    </center>

</BorderPane>