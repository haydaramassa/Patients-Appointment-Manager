<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinic.patientappointmentfrontend.PatientsController"
            styleClass="dashboard-root">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20"
              styleClass="top-bar">

            <padding>
                <Insets top="18" right="22" bottom="18" left="22"/>
            </padding>

            <Label fx:id="pageTitleLabel"
                   text="Patients"
                   styleClass="page-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Back to Dashboard"
                    onAction="#onBackClick"
                    prefWidth="260"
                    minHeight="46"
                    styleClass="back-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18"
              styleClass="content-area">

            <padding>
                <Insets top="22" right="22" bottom="22" left="22"/>
            </padding>

            <VBox spacing="14"
                  styleClass="form-card">

                <Label text="Patient Form"
                       styleClass="section-title"/>

                <HBox spacing="12"
                      alignment="CENTER_LEFT">

                    <TextField fx:id="firstNameField"
                               promptText="First Name"
                               prefWidth="200"
                               styleClass="input-field"/>

                    <TextField fx:id="lastNameField"
                               promptText="Last Name"
                               prefWidth="200"
                               styleClass="input-field"/>

                    <TextField fx:id="phoneField"
                               promptText="Phone"
                               prefWidth="190"
                               styleClass="input-field"/>

                    <TextField fx:id="emailField"
                               promptText="Email"
                               prefWidth="260"
                               styleClass="input-field"/>

                    <ComboBox fx:id="genderComboBox"
                              promptText="Gender"
                              prefWidth="150"
                              styleClass="input-field"/>

                    <DatePicker fx:id="birthDatePicker"
                                promptText="Birth Date"
                                prefWidth="170"
                                styleClass="input-field"/>
                </HBox>

                <HBox spacing="12"
                      alignment="CENTER_LEFT">

                    <TextField fx:id="addressField"
                               promptText="Address"
                               prefWidth="420"
                               styleClass="input-field"/>

                    <TextArea fx:id="notesField"
                              promptText="Notes"
                              prefWidth="420"
                              prefHeight="42"
                              styleClass="input-field"/>

                    <Button text="Create Patient"
                            onAction="#onCreatePatientClick"
                            prefWidth="190"
                            styleClass="login-button"/>

                    <Button text="Update Patient"
                            onAction="#onUpdatePatientClick"
                            prefWidth="180"
                            styleClass="toolbar-button"/>

                    <Button text="Clear Form"
                            onAction="#onClearFormClick"
                            prefWidth="150"
                            styleClass="toolbar-button"/>
                </HBox>

                <Label fx:id="statusLabel"
                       text="Ready"
                       wrapText="true"
                       styleClass="status-label"/>
            </VBox>

            <HBox spacing="10"
                  alignment="CENTER_LEFT">

                <TextField fx:id="searchField"
                           promptText="Search by name, phone, email, address, or notes"
                           prefWidth="430"
                           styleClass="input-field"/>

                <Button text="Search"
                        onAction="#onSearchClick"
                        styleClass="toolbar-button"/>

                <Button text="Refresh"
                        onAction="#onRefreshClick"
                        styleClass="toolbar-button"/>

                <Label text="Use row buttons to edit or delete patients."
                       styleClass="table-tip-label"/>
            </HBox>

            <TableView fx:id="patientsTable"
                       VBox.vgrow="ALWAYS"
                       styleClass="data-table">

                <columns>
                    <TableColumn fx:id="idColumn"
                                 text="ID"
                                 prefWidth="60"/>

                    <TableColumn fx:id="firstNameColumn"
                                 text="First Name"
                                 prefWidth="130"/>

                    <TableColumn fx:id="lastNameColumn"
                                 text="Last Name"
                                 prefWidth="130"/>

                    <TableColumn fx:id="phoneColumn"
                                 text="Phone"
                                 prefWidth="135"/>

                    <TableColumn fx:id="emailColumn"
                                 text="Email"
                                 prefWidth="220"/>

                    <TableColumn fx:id="genderColumn"
                                 text="Gender"
                                 prefWidth="95"/>

                    <TableColumn fx:id="birthDateColumn"
                                 text="Birth Date"
                                 prefWidth="120"/>

                    <TableColumn fx:id="addressColumn"
                                 text="Address"
                                 prefWidth="240"/>

                    <TableColumn fx:id="notesColumn"
                                 text="Notes"
                                 prefWidth="260"/>

                    <TableColumn fx:id="actionsColumn"
                                 text="Actions"
                                 prefWidth="190"/>
                </columns>

            </TableView>
        </VBox>
    </center>

</BorderPane>